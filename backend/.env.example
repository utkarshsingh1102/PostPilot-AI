# ============================================================
# PostPilot-AI  –  Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to version control.
# ============================================================

# --- PostgreSQL ---
DATABASE_URL=postgresql://postgres:password@localhost:5432/postpilot

# --- Anthropic / Claude ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-opus-4-6

# --- Google Gemini ---
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash-exp

# --- LinkedIn credentials (used by Playwright to log in) ---
# Required to scrape posts that need authentication.
LINKEDIN_EMAIL=your@email.com
LINKEDIN_PASSWORD=yourpassword

# --- Scraper ---
# How often (in hours) to run the scraping cron job.
SCRAPE_INTERVAL_HOURS=2
# Oldest post date to scrape (YYYY-MM-DD).
# The scraper stops scrolling once it hits a post older than this date.
# Set to "" (empty) to disable the cutoff and scrape all available posts.
SCRAPE_SINCE_DATE=2026-03-05

# --- Storage ---
# Directory where Gemini-generated images are saved.
GENERATED_IMAGES_DIR=generated_images

# --- App ---
APP_HOST=0.0.0.0
APP_PORT=8000
# Set to "true" to enable hot-reload and verbose logging.
DEBUG=false
